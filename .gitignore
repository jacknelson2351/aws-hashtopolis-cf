# Terraform downloaded providers and modules — regenerated by terraform init
.terraform/
.terraform.lock.hcl

# State files contain sensitive resource details and secrets
*.tfstate
*.tfstate.backup

# tfvars files often contain secrets (API keys, vouchers) — never commit these
*.tfvars
*.tfvars.json

# Generated Lambda zip — built by Terraform at apply time
lambda.zip
__pycache__/

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Packer artifacts
packer_cache/
*.pkr.hcl.lock.json

# Local installers/downloads
*.pkg

# Claude Code local settings (may contain IP addresses / session permissions)
.claude/

# Scratch/debug files
ssm-cache-hashcat-params.json
