# Terraform downloaded providers and modules — regenerated by terraform init
.terraform/

# State files contain sensitive resource details and secrets
*.tfstate
*.tfstate.backup

# tfvars files often contain secrets (API keys, vouchers) — never commit these
*.tfvars
*.tfvars.json

# Generated Lambda zip — built by Terraform at apply time
lambda.zip

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Packer artifacts
packer_cache/
*.pkr.hcl.lock.json
